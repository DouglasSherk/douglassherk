    <annotation encoding="application/x-tex">{\displaystyle {\begin{pmatrix}10&amp;20&amp;0&amp;0&amp;0&amp;0\\0&amp;30&amp;0&amp;40&amp;0&amp;0\\0&amp;0&amp;50&amp;60&amp;70&amp;0\\0&amp;0&amp;0&amp;0&amp;0&amp;80\\\end{pmatrix}}}</annotation>
